{
    "$schema": "https://unpkg.com/knip@5/schema.json",
    "entry": ["src/core/*.ts", "src/common/*.ts", "src/cli/*.ts"],
    "ignoreExportsUsedInFile": {
        "interface": true,
        "type": true
    },
    "ignore": ["src/cli/schemas/**", "src/templatesCompiled/**", "src/templates/**", "test/custom/**", "test/e2e/assets/**", "tools/jestSetup.ts"],
    "ignoreFiles": [
        "example/eslint.example.mjs",
        "src/cli/analyzeDiff/buildLegacyReport.ts",
        "src/cli/analyzeDiff/diffEngine.ts",
        "src/cli/analyzeDiff/logLegacyReport.ts",
        "src/cli/analyzeDiff/miracles.ts",
        "src/cli/analyzeDiff/report.ts",
        "src/cli/analyzeDiff/writeLegacyReport.ts",
        "src/common/utils/normalizeObject.ts",
        "src/common/Validation/index.ts",
        "src/common/VersionedSchema/refinements/singleOrMultiRefinement.ts",
        "src/core/utils/appendUniqueLinesToFile.ts",
        "src/cli/analyzeDiff/ignoreRules.ts",
        "src/cli/analyzeDiff/types.ts"
    ],
    "ignoreDependencies": [
        "abort-controller",
        "axios",
        "eslint-config-prettier",
        "eslint-plugin-lodash",
        "form-data",
        "node-fetch",
        "qs",
        "@types/axios",
        "@types/node-fetch",
        "@types/qs",
        "@types/winston"
    ],
    "tags": ["-lintignore"]
}
