{{#if @root.items}}
{
    "items": [
{{#each @root.items}}
        {
            "input": "{{input}}",
            "output": "{{output}}"{{#if request}},
            "request": "{{request}}"{{/if}}
        }{{#unless @last}},{{/unless}}
{{/each}}
    ],
    "httpClient": "{{@root.httpClient}}",
    "sortByRequired": {{@root.sortByRequired}},
    "enumPrefix": "{{@root.enumPrefix}}",
    "excludeCoreServiceFiles": {{@root.excludeCoreServiceFiles}},
    "interfacePrefix": "{{@root.interfacePrefix}}",
    "typePrefix": "{{@root.typePrefix}}",
    "useCancelableRequest": {{@root.useCancelableRequest}},
    "useOptions": {{@root.useOptions}},
    "useSeparatedIndexes": {{@root.useSeparatedIndexes}},
    "useUnionTypes": {{@root.useUnionTypes}},{{#if @root.request}},
    "request": "{{@root.request}}"{{/if}}
    "modelsMode": "{{@root.modelsMode}}",
    "useHistory": {{@root.useHistory}},
    "diffReport": "{{@root.diffReport}}"{{#if @root.request}},
    "request": "{{@root.request}}"{{/if}},
    "models": {
        "mode": "{{@root.modelsMode}}"
    },
    "analyze": {
        "useHistory": {{@root.useHistory}},
        "reportPath": "{{@root.diffReport}}"
    },
    "miracles": {
        "enabled": true,
        "confidence": 1,
        "types": ["RENAME", "TYPE_COERCION"]
    }
}
{{else}}
{
    "input": "{{@root.input}}",
    "output": "{{@root.output}}",
    "httpClient": "{{@root.httpClient}}",
    "sortByRequired": {{@root.sortByRequired}},
    "enumPrefix": "{{@root.enumPrefix}}",
    "excludeCoreServiceFiles": {{@root.excludeCoreServiceFiles}},
    "interfacePrefix": "{{@root.interfacePrefix}}",
    "typePrefix": "{{@root.typePrefix}}",
    "useCancelableRequest": {{@root.useCancelableRequest}},
    "useOptions": {{@root.useOptions}},
    "useSeparatedIndexes": {{@root.useSeparatedIndexes}},
    "useUnionTypes": {{@root.useUnionTypes}},{{#if @root.request}},
    "request": "{{@root.request}}"{{/if}}
    "modelsMode": "{{@root.modelsMode}}",
    "useHistory": {{@root.useHistory}},
    "diffReport": "{{@root.diffReport}}"{{#if @root.request}},
    "request": "{{@root.request}}"{{/if}},
    "models": {
        "mode": "{{@root.modelsMode}}"
    },
    "analyze": {
        "useHistory": {{@root.useHistory}},
        "reportPath": "{{@root.diffReport}}"
    },
    "miracles": {
        "enabled": true,
        "confidence": 1,
        "types": ["RENAME", "TYPE_COERCION"]
    }
}
{{/if}}
