{{>header}}

import type { ApiResult } from './ApiResult';
import type { TOpenAPIConfig } from './OpenAPI';
import { OpenAPI } from './OpenAPI';
import type { RequestExecutor, RequestConfig } from './executor/requestExecutor';
{{#if useCancelableRequest}}
import { CancelablePromise } from './CancelablePromise';
{{/if}}

/**
 * Typed per-request options (customize as needed).
 */
export interface MyCustomOptions {
    timeout?: number;
    retries?: number;
}

function buildUrl(config: RequestConfig, openApiConfig: TOpenAPIConfig = OpenAPI): string {
    const path = config.path.replace('{api-version}', openApiConfig.VERSION);
    return `${openApiConfig.BASE}${path}`;
}

/**
 * Custom RequestExecutor for direct service injection:
 *   const service = new SimpleService<MyCustomOptions>(customExecutor);
 *
 * For createClient integration use customExecutorPath with createExecutorAdapter scaffold instead.
 */
{{#if useCancelableRequest}}
export const customExecutor: RequestExecutor<MyCustomOptions> = {
    request<TResponse>(config: RequestConfig, options?: MyCustomOptions): CancelablePromise<TResponse> {
        return new CancelablePromise(async (resolve, reject, onCancel) => {
            try {
                const abortController = new AbortController();
                if (options?.timeout) {
                    const timeoutId = setTimeout(() => abortController.abort(), options.timeout);
                    onCancel(() => clearTimeout(timeoutId));
                }
                onCancel(() => abortController.abort());

                const response = await fetch(buildUrl(config), {
                    method: config.method,
                    headers: config.headers,
                    body: config.body ? JSON.stringify(config.body) : undefined,
                    signal: abortController.signal,
                });

                if (!response.ok) {
                    throw new Error(`Request failed: ${response.status} ${response.statusText}`);
                }

                resolve((await response.json()) as TResponse);
            } catch (error) {
                reject(error);
            }
        });
    },

    requestRaw<TResponse>(config: RequestConfig, options?: MyCustomOptions): CancelablePromise<ApiResult<TResponse>> {
        return new CancelablePromise(async (resolve, reject, onCancel) => {
            try {
                const abortController = new AbortController();
                if (options?.timeout) {
                    const timeoutId = setTimeout(() => abortController.abort(), options.timeout);
                    onCancel(() => clearTimeout(timeoutId));
                }
                onCancel(() => abortController.abort());

                const url = buildUrl(config);
                const response = await fetch(url, {
                    method: config.method,
                    headers: config.headers,
                    body: config.body ? JSON.stringify(config.body) : undefined,
                    signal: abortController.signal,
                });

                const body = (await response.json().catch(() => null)) as TResponse;
                resolve({
                    url,
                    ok: response.ok,
                    status: response.status,
                    statusText: response.statusText,
                    body,
                });
            } catch (error) {
                reject(error);
            }
        });
    },
};
{{else}}
export const customExecutor: RequestExecutor<MyCustomOptions> = {
    async request<TResponse>(config: RequestConfig, options?: MyCustomOptions): Promise<TResponse> {
        const response = await fetch(buildUrl(config), {
            method: config.method,
            headers: config.headers,
            body: config.body ? JSON.stringify(config.body) : undefined,
            signal: options?.timeout ? AbortSignal.timeout(options.timeout) : undefined,
        });

        if (!response.ok) {
            throw new Error(`Request failed: ${response.status} ${response.statusText}`);
        }

        return response.json() as Promise<TResponse>;
    },

    async requestRaw<TResponse>(config: RequestConfig, options?: MyCustomOptions): Promise<ApiResult<TResponse>> {
        const url = buildUrl(config);
        const response = await fetch(url, {
            method: config.method,
            headers: config.headers,
            body: config.body ? JSON.stringify(config.body) : undefined,
            signal: options?.timeout ? AbortSignal.timeout(options.timeout) : undefined,
        });

        const body = (await response.json().catch(() => null)) as TResponse;
        return {
            url,
            ok: response.ok,
            status: response.status,
            statusText: response.statusText,
            body,
        };
    },
};
{{/if}}
