/**
 * Swarm API Server
 * Automatically generated HTTP server for {{swarmName}} coordination
 */

import http from 'http';

import { {{swarmNameCamel}}Coordinator } from './coordinator';

const DEFAULT_PORT = {{port}};

const avatars: Array<{ name: string; serviceId: string }> = [
{{#each avatars}}
  { name: '{{name}}', serviceId: '{{serviceId}}' },
{{/each}}
];

function sendJson(res: http.ServerResponse, statusCode: number, data: unknown): void {
  res.writeHead(statusCode, { 'Content-Type': 'application/json' });
  res.end(JSON.stringify(data));
}

function parseJsonBody(req: http.IncomingMessage): Promise<Record<string, unknown>> {
  return new Promise((resolve, reject) => {
    let body = '';

    req.on('data', chunk => {
      body += chunk;
    });

    req.on('end', () => {
      try {
        resolve(body ? JSON.parse(body) : {});
      } catch (error) {
        reject(error);
      }
    });

    req.on('error', reject);
  });
}

export function createApiServer(): http.Server {
  return http.createServer(async (req, res) => {
    const url = req.url?.split('?')[0] ?? '/';
    const method = req.method ?? 'GET';

    try {
      if (method === 'GET' && url === '/health') {
        sendJson(res, 200, {
          healthy: {{swarmNameCamel}}Coordinator.isHealthy(),
          services: {{swarmNameCamel}}Coordinator.getHealthStatus(),
        });
        return;
      }

      if (method === 'GET' && url === '/services') {
        sendJson(res, 200, { avatars });
        return;
      }

      if (method === 'POST' && url === '/consensus/propose') {
        const body = await parseJsonBody(req);
        const operationId = body.operationId;
        const operation = body.operation;
        const services = body.services;

        if (
          typeof operationId !== 'string' ||
          typeof operation !== 'string' ||
          !Array.isArray(services)
        ) {
          sendJson(res, 400, { error: 'Missing operationId, operation, or services array' });
          return;
        }

        const result = await {{swarmNameCamel}}Coordinator.proposeConsensus(
          operationId,
          operation,
          services as string[]
        );
        sendJson(res, 200, result);
        return;
      }

      if (method === 'GET' && url === '/metrics') {
        sendJson(res, 200, {
          health: {{swarmNameCamel}}Coordinator.getHealthStatus(),
          avatarCount: avatars.length,
        });
        return;
      }

      sendJson(res, 404, { error: 'Not found' });
    } catch (error) {
      sendJson(res, 500, {
        error: error instanceof Error ? error.message : 'Internal server error',
      });
    }
  });
}

export function startApiServer(port: number = DEFAULT_PORT): http.Server {
  const server = createApiServer();
  server.listen(port, () => {
    console.log(`Swarm API server listening on port ${port}`);
  });
  return server;
}
