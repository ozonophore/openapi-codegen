function isBinary(value: any): value is Buffer | ArrayBuffer | ArrayBufferView | Blob {
    const isBuffer = Buffer.isBuffer(value);
    const isArrayBuffer = types.isArrayBuffer(value);
    const isArrayBufferView = types.isArrayBufferView(value);
    const isBlob = typeof Blob !== 'undefined' && value instanceof Blob;
    return isBuffer || isArrayBuffer || isArrayBufferView || isBlob;
}
