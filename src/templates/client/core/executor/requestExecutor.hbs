{{>header}}

import type { ApiResult } from '../ApiResult';
{{#if @root.useCancelableRequest}}
import type { CancelablePromise } from '../CancelablePromise';

type ExecutorReturn<T> = CancelablePromise<T>;
{{else}}
type ExecutorReturn<T> = Promise<T>;
{{/if}}

export interface RequestConfig {
  method: string;
  path: string;

  headers?: Record<string, string>;
  query?: Record<string, any>;
  body?: unknown;

  requestMediaType?: string;
  responseType?: 'blob';
  cookies?: Record<string, string>;
}

export interface RequestExecutor<TOptions = unknown> {
  request<TResponse>(
    config: RequestConfig,
    options?: TOptions
  ): ExecutorReturn<TResponse>;

  requestRaw<TResponse>(
    config: RequestConfig,
    options?: TOptions
  ): ExecutorReturn<ApiResult<TResponse>>;
}
