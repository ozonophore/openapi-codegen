import type { RequestConfig } from '../executor/requestExecutor';

export type RequestInterceptor =
  (config: RequestConfig) => RequestConfig | Promise<RequestConfig>;

export type ResponseInterceptor<T = unknown> =
  (response: T, context: RequestConfig) => T | Promise<T>;

export type ErrorInterceptor =
  (error: unknown, context: RequestConfig) => unknown | Promise<unknown>;

/**
 * Return from an ErrorInterceptor to recover from a failed request instead of re-throwing.
 * The recovered value is passed through onResponse interceptors.
 */
export class RequestRecovery<T = unknown> {
  constructor(public readonly value: T) {}
}
