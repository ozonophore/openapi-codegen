import type { ApiResult } from '../ApiResult';
import type { RequestInterceptor, ResponseInterceptor, ErrorInterceptor } from './interceptors';
import { RequestRecovery } from './interceptors';
import type { RequestConfig, RequestExecutor } from '../executor/requestExecutor';

export function withInterceptors<TOptions extends Record<string, any> = Record<string, never>>(
    executor: RequestExecutor<TOptions>,
    interceptors: {
        onRequest?: RequestInterceptor[];
        onResponse?: ResponseInterceptor[];
        onError?: ErrorInterceptor[];
    }
): RequestExecutor<TOptions> {
    const runRequestInterceptors = async (config: RequestConfig): Promise<RequestConfig> => {
        let currentConfig = config;

        for (const interceptor of interceptors.onRequest ?? []) {
            currentConfig = await interceptor(currentConfig);
        }

        return currentConfig;
    };

    const runResponseInterceptors = async <TResponse>(
        response: TResponse,
        config: RequestConfig
    ): Promise<TResponse> => {
        let currentResponse = response;

        for (const interceptor of interceptors.onResponse ?? []) {
            currentResponse = (await interceptor(currentResponse, config)) as TResponse;
        }

        return currentResponse;
    };

    return {
        async request<TResponse>(config: RequestConfig, options?: TOptions): Promise<TResponse> {
            let currentConfig = config;

            try {
                currentConfig = await runRequestInterceptors(config);
                const response = await executor.request<TResponse>(currentConfig, options);

                return runResponseInterceptors(response, currentConfig);
            } catch (caught) {
                let error = caught;

                for (const interceptor of interceptors.onError ?? []) {
                    const result = await interceptor(error, currentConfig);

                    if (result instanceof RequestRecovery) {
                        return runResponseInterceptors(result.value as TResponse, currentConfig);
                    }

                    error = result;
                }

                throw error;
            }
        },
        async requestRaw<TResponse>(config: RequestConfig, options?: TOptions): Promise<ApiResult<TResponse>> {
            let currentConfig = config;

            try {
                currentConfig = await runRequestInterceptors(config);
                const response = await executor.requestRaw<TResponse>(currentConfig, options);

                return runResponseInterceptors(response, currentConfig);
            } catch (caught) {
                let error = caught;

                for (const interceptor of interceptors.onError ?? []) {
                    const result = await interceptor(error, currentConfig);

                    if (result instanceof RequestRecovery) {
                        return runResponseInterceptors(result.value as ApiResult<TResponse>, currentConfig);
                    }

                    error = result;
                }

                throw error;
            }
        },
    };
}
