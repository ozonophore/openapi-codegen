{{#if description}}
/**
 * {{{description}}}
 */
{{/if}}
export interface {{{name}}} {
    {{#each properties}}
    {{#if description}}
    /**
     * {{{description}}}
     {{#if diff}}
     {{#if diff.previousType}}
     * @info previous type: {{{diff.previousType}}}
     {{/if}}
     {{/if}}
     */
    {{else}}
    {{#if diff}}
    {{#if diff.previousType}}
    /**
     * @info previous type: {{{diff.previousType}}}
     */
    {{/if}}
    {{/if}}
    {{/if}}
    {{>isReadOnly}}{{{name}}}{{>isRequired}}: {{>type parent=../name}};
    {{/each}}
    {{#if ghostProperties}}
    {{#each ghostProperties}}
    /**
     * @deprecated Removed from API
     */
    {{{name}}}?: unknown;
    {{/each}}
    {{/if}}
}
{{#if enums}}
{{#unless @root.useUnionTypes}}

export namespace {{{name}}} {

    {{#each enums}}
    {{#if description}}
    /**
     * {{{description}}}
     */
    {{/if}}
    {{#if alias}}
    export enum {{{alias}}} {
    {{else}}
    export enum {{{name}}} {
    {{/if}}
        {{#each enum}}
        {{{name}}} = {{{value}}},
        {{/each}}
    }

    {{/each}}

}
{{/unless}}
{{/if}}
