/* {{autogenerated}} */

/**
 * Connection pool for reusing HTTP connections
 */

export interface ConnectionPoolConfig {
  minSize?: number;
  maxSize?: number;
  acquireTimeoutMs?: number;
}

export class ConnectionPool<T = unknown> {
  private connections: T[] = [];
  private created = 0;
  private readonly minSize: number;
  private readonly maxSize: number;
  private readonly acquireTimeoutMs: number;
  private readonly createConnection: () => T;

  constructor(
    createConnection: () => T,
    config?: ConnectionPoolConfig
  ) {
    this.createConnection = createConnection;
    this.minSize = config?.minSize ?? 5;
    this.maxSize = config?.maxSize ?? 20;
    this.acquireTimeoutMs = config?.acquireTimeoutMs ?? 5000;
    this.initializePool();
  }

  private initializePool(): void {
    for (let i = 0; i < this.minSize; i++) {
      this.connections.push(this.createConnection());
      this.created++;
    }
  }

  async acquire(): Promise<T> {
    if (this.connections.length > 0) {
      return this.connections.pop()!;
    }

    if (this.created < this.maxSize) {
      this.created++;
      return this.createConnection();
    }

    const deadline = Date.now() + this.acquireTimeoutMs;
    return new Promise((resolve, reject) => {
      const checkInterval = setInterval(() => {
        if (this.connections.length > 0) {
          clearInterval(checkInterval);
          resolve(this.connections.pop()!);
          return;
        }

        if (Date.now() >= deadline) {
          clearInterval(checkInterval);
          reject(new Error('Connection pool acquire timeout'));
        }
      }, 50);
    });
  }

  release(connection: T): void {
    if (this.connections.length < this.maxSize) {
      this.connections.push(connection);
    }
  }

  getStats(): { idle: number; created: number; maxSize: number } {
    return {
      idle: this.connections.length,
      created: this.created,
      maxSize: this.maxSize,
    };
  }
}
