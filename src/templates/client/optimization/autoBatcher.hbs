/**
 * Auto-batching middleware for API requests
 * Batches multiple API calls into single batch endpoint calls
 */

export interface BatchRequest {
  id: string;
  endpoint: string;
  method: string;
  params?: Record<string, any>;
  data?: any;
}

export interface BatchResponse {
  id: string;
  status: number;
  data?: any;
  error?: any;
}

export class AutoBatchingMiddleware {
  private batchQueue: Array<{ request: BatchRequest; resolve: (value: any) => void; reject: (error: any) => void }> = [];
  private batchTimer: NodeJS.Timeout | null = null;
  private readonly batchSize: number;
  private readonly batchDelayMs: number;
  private readonly batchEndpoint: string;
  private sequenceId = 0;

  constructor(batchEndpoint: string, batchSize: number = 10, batchDelayMs: number = 50) {
    this.batchEndpoint = batchEndpoint;
    this.batchSize = batchSize;
    this.batchDelayMs = batchDelayMs;
  }

  /**
   * Queue a request for batching
   */
  async batchRequest(request: BatchRequest): Promise<BatchResponse> {
    return new Promise((resolve, reject) => {
      this.batchQueue.push({ request, resolve, reject });

      if (this.batchQueue.length >= this.batchSize) {
        this.flushBatch();
      } else if (!this.batchTimer) {
        this.batchTimer = setTimeout(() => this.flushBatch(), this.batchDelayMs);
      }
    });
  }

  /**
   * Flush pending batch
   */
  private async flushBatch(): Promise<void> {
    if (this.batchTimer) {
      clearTimeout(this.batchTimer);
      this.batchTimer = null;
    }

    if (this.batchQueue.length === 0) return;

    const batch = this.batchQueue.splice(0, this.batchSize);

    try {
      const response = await this.callBatchEndpoint(batch.map(b => b.request));

      if (Array.isArray(response)) {
        batch.forEach((item, index) => {
          if (response[index]) {
            item.resolve(response[index]);
          } else {
            item.reject(new Error(`No response for batch item ${index}`));
          }
        });
      } else {
        batch.forEach(item => item.reject(new Error('Invalid batch response format')));
      }
    } catch (error) {
      batch.forEach(item => item.reject(error));
    }
  }

  /**
   * Call the batch endpoint
   */
  private async callBatchEndpoint(requests: BatchRequest[]): Promise<BatchResponse[]> {
