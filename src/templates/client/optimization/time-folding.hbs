/* {{autogenerated}} */

/**
 * Time-folding batcher
 * Buffers requests within a time window and flushes them as a batch
 */

export interface TimeFoldingConfig {
  windowMs?: number;
  maxBufferSize?: number;
}

interface BufferedItem<T> {
  item: T;
  resolve: (value: T[]) => void;
}

export class TimeFoldingBatcher<T = unknown> {
  private buffer: BufferedItem<T>[] = [];
  private flushTimer: ReturnType<typeof setTimeout> | null = null;
  private readonly windowMs: number;
  private readonly maxBufferSize: number;

  constructor(config?: TimeFoldingConfig) {
    this.windowMs = config?.windowMs ?? 100;
    this.maxBufferSize = config?.maxBufferSize ?? 100;
  }

  async batch(item: T): Promise<T[]> {
    return new Promise((resolve) => {
      this.buffer.push({ item, resolve });

      if (this.buffer.length >= this.maxBufferSize) {
        this.flush();
      } else if (!this.flushTimer) {
        this.flushTimer = setTimeout(() => this.flush(), this.windowMs);
      }
    });
  }

  private flush(): void {
    if (this.flushTimer) {
      clearTimeout(this.flushTimer);
      this.flushTimer = null;
    }

    if (this.buffer.length === 0) {
      return;
    }

    const batch = this.buffer.splice(0);
    const result = batch.map(entry => entry.item);
    batch.forEach(entry => entry.resolve(result));
  }

  getBufferSize(): number {
    return this.buffer.length;
  }

  dispose(): void {
    if (this.flushTimer) {
      clearTimeout(this.flushTimer);
      this.flushTimer = null;
    }
    this.buffer = [];
  }
}
