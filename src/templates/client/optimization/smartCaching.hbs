/**
 * Smart caching layer for API responses
 * Respects Cache-Control headers and implements TTL-based expiration
 */

export interface CacheEntry<T> {
  value: T;
  expiresAt: number;
  headers?: Record<string, string>;
}

export interface CacheConfig {
  defaultTTLMs?: number;
  maxEntries?: number;
  enableStaleWhileRevalidate?: boolean;
}

export class SmartCache<T> {
  private cache = new Map<string, CacheEntry<T>>();
  private readonly defaultTTLMs: number;
  private readonly maxEntries: number;
  private readonly enableStaleWhileRevalidate: boolean;

  constructor(config?: CacheConfig) {
    this.defaultTTLMs = config?.defaultTTLMs || 5 * 60 * 1000; // 5 minutes
    this.maxEntries = config?.maxEntries || 1000;
    this.enableStaleWhileRevalidate = config?.enableStaleWhileRevalidate ?? true;
  }

  /**
   * Get value from cache or execute function
   */
  async get<R>(key: string, fn: () => Promise<R>, headers?: Record<string, string>): Promise<R> {
    const cached = this.cache.get(key);

    if (cached && cached.expiresAt > Date.now()) {
      return cached.value as R;
    }

    // Stale while revalidate: return stale data while revalidating in background
    if (this.enableStaleWhileRevalidate && cached && cached.expiresAt <= Date.now()) {
      this.revalidateInBackground(key, fn, headers);
      return cached.value as R;
    }

    const value = await fn();
    this.set(key, value, headers);
    return value;
  }

  /**
   * Set value in cache
   */
  set<R>(key: string, value: R, headers?: Record<string, string>): void {
    const ttl = this.parseCacheControl(headers?.['cache-control'] || headers?.['Cache-Control']);
    const expiresAt = Date.now() + (ttl || this.defaultTTLMs);

    // Remove oldest entry if cache is full
    if (this.cache.size >= this.maxEntries) {
      const firstKey = this.cache.keys().next().value;
      if (firstKey) {
        this.cache.delete(firstKey);
      }
    }

    this.cache.set(key, {
      value: value as any,
      expiresAt,
      headers,
    });
  }

  /**
   * Clear specific or all cache entries
   */
  clear(key?: string): void {
    if (key) {
      this.cache.delete(key);
    } else {
      this.cache.clear();
    }
  }

  /**
   * Clean up expired entries
   */
  cleanup(): void {
    const now = Date.now();
    for (const [key, entry] of this.cache.entries()) {
      if (entry.expiresAt < now) {
        this.cache.delete(key);
      }
    }
  }

  /**
   * Get cache statistics
   */
  getStats(): { size: number; maxEntries: number; hitRate?: string } {
    return {
      size: this.cache.size,
      maxEntries: this.maxEntries,
    };
  }

  /**
   * Parse Cache-Control header for TTL
   */
  private parseCacheControl(cacheControl?: string): number | null {
    if (!cacheControl) return null;

    const maxAgeMatch = cacheControl.match(/max-age=(\d+)/);
    if (maxAgeMatch) {
      return parseInt(maxAgeMatch[1], 10) * 1000;
    }

    const sMaxAgeMatch = cacheControl.match(/s-maxage=(\d+)/);
    if (sMaxAgeMatch) {
      return parseInt(sMaxAgeMatch[1], 10) * 1000;
    }

    return null;
  }

  /**
   * Revalidate cache in background
   */
  private async revalidateInBackground<R>(
    key: string,
    fn: () => Promise<R>,
    headers?: Record<string, string>
  ): Promise<void> {
    try {
      const newValue = await fn();
      this.set(key, newValue, headers);
    } catch (error) {
      // Silently fail background revalidation
    }
  }
}

/**
 * Cache key builder for consistent key generation
 */
export class CacheKeyBuilder {
  /**
   * Build cache key from endpoint and parameters
   */
  static buildKey(endpoint: string, params?: Record<string, any>, method?: string): string {
    const keyParts = [method || 'GET', endpoint];

    if (params && Object.keys(params).length > 0) {
      const sortedParams = Object.keys(params)
        .sort()
        .map(k => `${k}=${JSON.stringify(params[k])}`)
        .join('&');
      keyParts.push(sortedParams);
    }

    return keyParts.join(':');
  }

  /**
   * Build cache key from request object
   */
  static buildKeyFromRequest(request: any): string {
    return this.buildKey(request.url || request.endpoint, request.params || request.query, request.method);
  }
}
