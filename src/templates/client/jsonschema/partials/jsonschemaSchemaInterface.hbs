{
    type: 'object',
{{#if properties}}
    properties: {
{{#each properties}}
        {{{name}}}: {{>jsonschemaSchema}}{{#unless @last}},{{/unless}}
{{/each}}
    },
{{#each properties}}
{{#if isRequired}}
{{#if @first}}
    required: ['{{{name}}}'
{{else}}
    , '{{{name}}}'
{{/if}}
{{#if @last}}
    ],
{{/if}}
{{/if}}
{{/each}}
{{else}}
    properties: {},
{{/if}}
{{#if maxProperties}}
    maxProperties: {{{maxProperties}}},
{{/if}}
{{#if minProperties}}
    minProperties: {{{minProperties}}},
{{/if}}
{{#if isNullable}}
    nullable: true,
{{/if}}
    additionalProperties: false
}