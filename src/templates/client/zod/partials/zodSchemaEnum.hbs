{{#if enum}}
{{#if (eq (first enum).type 'number')}}
z.union([
{{#each enum}}
    z.literal({{{value}}}){{#unless @last}},{{/unless}}
{{/each}}
]){{#if isNullable}}.nullable(){{/if}}
{{else}}
z.enum([
{{#each enum}}
    {{{value}}}{{#unless @last}},{{/unless}}
{{/each}}
]){{#if isNullable}}.nullable(){{/if}}
{{/if}}
{{else}}
z.any(){{#if isNullable}}.nullable(){{/if}}
{{/if}}