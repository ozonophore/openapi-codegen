/* istanbul ignore file */
/* tslint:disable */
/* eslint-disable */

import type { IModelWithString } from '../models/ModelWithString';
import type { RequestExecutor, RequestConfig } from '../core/executor/requestExecutor';
import type { ApiResult } from '../core/ApiResult';

const multipartResponse = (): RequestConfig => ({
    method: 'GET',
    path: `/api/v{api-version}/multipart`,
});

const multipartRequest = (formData?: { content?: Blob; data?: IModelWithString | null }): RequestConfig => ({
    method: 'POST',
    path: `/api/v{api-version}/multipart`,

    body: formData,
    requestMediaType: 'multipart/form-data',
});

export type TMultipartOptions = {
    multipartResponse: () => RequestConfig;
    multipartRequest: (formData?: { content?: Blob; data?: IModelWithString | null }) => RequestConfig;
};

export const MultipartOptions: TMultipartOptions = {
    multipartResponse: multipartResponse,
    multipartRequest: multipartRequest,
};

export class MultipartService<TOptions = unknown> {
    constructor(private readonly executor: RequestExecutor<TOptions>) {}

    /**
     * @returns any OK
     * @throws ApiError
     */
    public multipartResponse(options?: TOptions): Promise<{
        file?: Blob;
        metadata?: {
            foo?: string;
            bar?: string;
        };
    }> {
        return this.executor.request<{
            file?: Blob;
            metadata?: {
                foo?: string;
                bar?: string;
            };
        }>(MultipartOptions.multipartResponse(), options);
    }

    public multipartResponseRaw(options?: TOptions): Promise<
        ApiResult<{
            file?: Blob;
            metadata?: {
                foo?: string;
                bar?: string;
            };
        }>
    > {
        return this.executor.requestRaw<{
            file?: Blob;
            metadata?: {
                foo?: string;
                bar?: string;
            };
        }>(MultipartOptions.multipartResponse(), options);
    }
    /**
     * @param formData
     * @throws ApiError
     */
    public multipartRequest(
        formData?: {
            content?: Blob;
            data?: IModelWithString | null;
        },
        options?: TOptions,
    ): Promise<void> {
        return this.executor.request<void>(MultipartOptions.multipartRequest(formData), options);
    }

    public multipartRequestRaw(
        formData?: {
            content?: Blob;
            data?: IModelWithString | null;
        },
        options?: TOptions,
    ): Promise<ApiResult<void>> {
        return this.executor.requestRaw<void>(MultipartOptions.multipartRequest(formData), options);
    }
}
