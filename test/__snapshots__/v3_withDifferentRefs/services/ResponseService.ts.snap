import type { IModelWithStringLocal } from '../models/ModelWithStringLocal';
import type { IModelWithString } from '../models/schemas/base/ModelWithString';
import type { TModelThatExtends } from '../models/schemas/compositions/ModelThatExtends';
import type { INested } from '../models/schemas/compositions/Nested';
import type { RequestExecutor, RequestConfig } from '../core/executor/requestExecutor';
import type { ApiResult } from '../core/ApiResult';

const callWithResponse = (): RequestConfig => ({
    method: 'GET',
    path: `/api/v{api-version}/response`,
});

const callWithDuplicateResponses = (): RequestConfig => ({
    method: 'POST',
    path: `/api/v{api-version}/response`,
});

const callWithResponses = (): RequestConfig => ({
    method: 'PUT',
    path: `/api/v{api-version}/response`,
});

export type TResponseOptions = {
    callWithResponse: () => RequestConfig;
    callWithDuplicateResponses: () => RequestConfig;
    callWithResponses: () => RequestConfig;
};

export const ResponseOptions: TResponseOptions = {
    callWithResponse: callWithResponse,
    callWithDuplicateResponses: callWithDuplicateResponses,
    callWithResponses: callWithResponses,
};

export class ResponseService<TOptions = unknown> {
    constructor(private readonly executor: RequestExecutor<TOptions>) {}

    /**
     * @returns void
     * @throws ApiError
     */
    public callWithResponse(options?: TOptions): Promise<void> {
        return this.executor.request<void>(ResponseOptions.callWithResponse(), options);
    }

    public callWithResponseRaw(options?: TOptions): Promise<ApiResult<void>> {
        return this.executor.requestRaw<void>(ResponseOptions.callWithResponse(), options);
    }
    /**
     * @returns IModelWithString Message for 201 response
     * @throws ApiError
     */
    public callWithDuplicateResponses(options?: TOptions): Promise<IModelWithString> {
        return this.executor.request<IModelWithString>(ResponseOptions.callWithDuplicateResponses(), options);
    }

    public callWithDuplicateResponsesRaw(options?: TOptions): Promise<ApiResult<IModelWithString>> {
        return this.executor.requestRaw<IModelWithString>(ResponseOptions.callWithDuplicateResponses(), options);
    }
    /**
     * @returns any Successful response
     * @returns TModelThatExtends Message for 201 response
     * @returns INested Message for 202 response
     * @throws ApiError
     */
    public callWithResponses(options?: TOptions): Promise<
        | {
              readonly '@namespace.string'?: string;
              readonly '@namespace.integer'?: number;
              readonly value?: Array<IModelWithStringLocal>;
          }
        | TModelThatExtends
        | INested
    > {
        return this.executor.request<
            | {
                  readonly '@namespace.string'?: string;
                  readonly '@namespace.integer'?: number;
                  readonly value?: Array<IModelWithStringLocal>;
              }
            | TModelThatExtends
            | INested
        >(ResponseOptions.callWithResponses(), options);
    }

    public callWithResponsesRaw(options?: TOptions): Promise<
        ApiResult<
            | {
                  readonly '@namespace.string'?: string;
                  readonly '@namespace.integer'?: number;
                  readonly value?: Array<IModelWithStringLocal>;
              }
            | TModelThatExtends
            | INested
        >
    > {
        return this.executor.requestRaw<
            | {
                  readonly '@namespace.string'?: string;
                  readonly '@namespace.integer'?: number;
                  readonly value?: Array<IModelWithStringLocal>;
              }
            | TModelThatExtends
            | INested
        >(ResponseOptions.callWithResponses(), options);
    }
}
