/* tslint:disable */
/* eslint-disable */

import type { RequestExecutor, RequestConfig } from '../core/executor/requestExecutor';
import type { ApiResult } from '../core/ApiResult';

const callWithCircularModel = (): RequestConfig => ({
    method: 'GET',
    path: `/api/v{api-version}/circular`,
});

export type TCircularOptions = {
    callWithCircularModel: () => RequestConfig;
};

export const CircularOptions: TCircularOptions = {
    callWithCircularModel: callWithCircularModel,
};

export class CircularService<TOptions = unknown> {
    constructor(private readonly executor: RequestExecutor<TOptions>) {}

    /**
     * @returns void
     * @throws ApiError
     */
    public callWithCircularModel(options?: TOptions): Promise<void> {
        return this.executor.request<void>(CircularOptions.callWithCircularModel(), options);
    }

    public callWithCircularModelRaw(options?: TOptions): Promise<ApiResult<void>> {
        return this.executor.requestRaw<void>(CircularOptions.callWithCircularModel(), options);
    }
}
