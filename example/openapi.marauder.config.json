{
    "httpClient": "fetch",
    "useUnionTypes": true,
    "cache": true,
    "cacheStrategy": "reuse",
    "reuseOnConflict": "namespace",
    "reuseMode": "auto-group",
    "preAnalyze": true,
    "workspaceReport": {
        "enabled": true,
        "path": "./reports/workspace-report",
        "format": "both"
    },
    "trafficSplitter": {
        "enabled": true,
        "strategy": "weighted",
        "oldClientWeight": 80,
        "newClientWeight": 20,
        "stickySessions": true,
        "sessionDuration": "1h"
    },
    "swarm": {
        "enabled": true,
        "output": "./reports/swarm-manifest.json"
    },
    "items": [
        {
            "input": "./test/spec/lom/lom_api.yaml",
            "output": "./test/generated/lom_api/"
        },
        {
            "input": "./test/spec/lom/lom_api.v1.yaml",
            "output": "./test/generated/lom_api_v2/"
        },
        {
            "input": "./test/spec/v3.json",
            "output": "./test/generated/v3/"
        }
    ]
}
